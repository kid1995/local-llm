# ============================================================
# Local LLM Stack -- Configuration
# ============================================================
# Copy this file or edit in place. All values have safe defaults.
# Changes take effect on next: docker compose up
# ============================================================

# --- Model Selection ---
# Change this to switch the entire stack to a different model.
# Examples:
#   qwen2.5-coder:3b      (8 GB RAM, fast, lower quality)
#   qwen2.5-coder:7b      (16 GB RAM, good balance)       <-- default
#   qwen2.5-coder:14b     (32 GB RAM, high quality)
#   qwen2.5-coder:32b     (64 GB RAM, near-frontier)
#   qwen3.5:9b            (32 GB RAM, next-gen)
#   qwen3.5:27b           (64 GB RAM, next-gen frontier)
LLM_MODEL=qwen2.5-coder:7b

# --- Embedding Model ---
# Used for RAG / code search. nomic-embed-text is lightweight (~300 MB).
EMBEDDING_MODEL=nomic-embed-text

# --- Inference Parameters ---
# Context window size (tokens). Higher = more code context, more RAM.
#   2048  -- minimal, fast (default Ollama)
#   4096  -- good for single-file tasks
#   8192  -- multi-file context
#   16384 -- large context (needs more RAM)
NUM_CTX=4096

# Temperature (0.0 = deterministic, 1.0 = creative)
TEMPERATURE=0.2

# Top-p sampling (lower = more focused)
TOP_P=0.9

# --- Resource Limits ---
# Max models loaded simultaneously (1 recommended for 16 GB)
MAX_LOADED_MODELS=1

# Unload model after inactivity (e.g., 5m, 10m, 1h)
KEEP_ALIVE=10m

# --- Network ---
# Port for Ollama API (clients connect here)
OLLAMA_PORT=11434

# SECURITY: Bind address. 127.0.0.1 = local only, 0.0.0.0 = network accessible
# Only change to 0.0.0.0 if you need other machines to connect (e.g., shared server)
OLLAMA_HOST=127.0.0.1

# --- Versions (pinned for reproducibility) ---
# Update these when the team agrees on a new verified version.
OLLAMA_VERSION=0.6.2
