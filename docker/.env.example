# ============================================================
# Local LLM Stack -- Configuration Template
# ============================================================
# Copy to .env and adjust:  cp .env.example .env
# ============================================================

# Model: pick one that fits your RAM
LLM_MODEL=qwen2.5-coder:7b
EMBEDDING_MODEL=nomic-embed-text

# Inference
NUM_CTX=4096
TEMPERATURE=0.2
TOP_P=0.9

# Resources
MAX_LOADED_MODELS=1
KEEP_ALIVE=10m

# Network
OLLAMA_PORT=11434
OLLAMA_HOST=127.0.0.1

# Pinned versions
OLLAMA_VERSION=0.6.2
